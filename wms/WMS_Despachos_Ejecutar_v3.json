      "parameters": {
        "jsCode": "const html = $input.item.json.data || '';\nconst grupo = $('Split Grupos').item.json;\nconst cookieActiva = grupo.cookieActiva || grupo.cookieNormal;\n\nconst fields = {};\nconst inputPattern = /<input[^>]*name=\"([^\"]*)\"[^>]*value=\"([^\"]*)\"[^>]*>/gi;\nlet m;\nwhile ((m = inputPattern.exec(html)) !== null) {\n  if (!fields[m[1]]) fields[m[1]] = m[2]; // no sobreescribir duplicados\n}\n\nif (!fields['casillero']) {\n  return [{ json: { ...grupo, _formOk: false, _error: 'Form vacío', cookieActiva }}];\n}\n\nreturn [{ json: { ...grupo, _formOk: true, _formFields: fields, cookieActiva }}];\n"
      },
