      "id": "6caa32e9-1ecb-4535-929b-0262a39aea73",
      "name": "Buscar en Despachos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const html = $input.item.json.data || '';\nconst cookieNormal = $('Extraer Cookies y IDs').item.json.cookieNormal;\nconst casilleroIds = $('Extraer Cookies y IDs').item.json.casilleroIds || [];\n\nif (html.length < 500) throw new Error('HTML muy pequeño - error de sesión');\n\nconst rows = [];\nconst whrPattern = /<span class=\"titulos\">(WHR\\d+)<\\/span>/g;\nlet match;\n\nwhile ((match = whrPattern.exec(html)) !== null) {\n  const whr = match[1];\n  const block = html.substring(match.index, match.index + 3000);\n\n  const midM = block.match(/manifiesto_id\" value=\"(\\d+)\"/);\n  const manifestoId = midM ? midM[1] : '';\n\n  const creaM = block.match(/crea_guia\\('WHR\\d+','(\\d+)'\\)/);\n  const casilleroId = creaM ? creaM[1] : '';\n\n  // Solo los casilleros que vienen en el request\n  if (!casilleroIds.includes(casilleroId)) continue;\n\n  const tdMatches = [...block.matchAll(/<td class=\"reciboSMALLCAP\">\\s*([\\s\\S]*?)\\s*<\\/[Tt][Dd]>/g)];\n  const agencia = tdMatches[0] ? tdMatches[0][1].trim().replace(/<[^>]+>/g,'').replace(/\\s+/g,' ') : '';\n\n  const pesoM = block.match(/name=\"pes_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const peso = parseFloat(pesoM ? pesoM[1].trim() : '0') || 0;\n\n  const desM = block.match(/name=\"des_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const contenido = desM ? desM[1].trim() : '';\n\n  const decM = block.match(/name=\"dec_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const valorDec = decM ? decM[1].trim() : '0';\n\n  const contenidoLower = contenido.toLowerCase();\n  const esDG = ['dg', 'un'].some(p => contenidoLower.includes(p));\n\n  rows.push({ whr, manifestoId, casilleroId, agencia, peso, contenido, valorDec, esDG });\n}\n\n// Agrupar por casillero\nconst grupos = {};\nfor (const r of rows) {\n  const key = r.casilleroId;\n  if (!grupos[key]) grupos[key] = [];\n  grupos[key].push(r);\n}\n\nconst resultados = [];\nfor (const [casId, guias] of Object.entries(grupos)) {\n  const tieneDG = guias.some(g => g.esDG);\n  const paItems = guias.map(g => `${g.peso}x0x0x0x${g.manifestoId}`);\n  resultados.push({\n    casilleroId:  casId,\n    agencia:      guias[0].agencia,\n    tipo:         tieneDG ? 'DG' : 'NORMAL',\n    whrsValidos:  guias.map(g => g.whr),\n    whrsStr:      guias.map(g => `'${g.whr}'`).join(','),\n    whrsBuscar:   guias.map(g => g.whr).join('%7C'),\n    pa:           paItems.join('|'),\n    piezas:       guias.length,\n    pesoTotal:    guias.reduce((s, g) => s + g.peso, 0).toFixed(2),\n    descripcion:  guias.map(g => g.contenido).join('\\n'),\n    valdec:       guias.reduce((s, g) => s + (parseFloat(g.valorDec) || 0), 0),\n    primerWhr:    guias[0].whr,\n    cookieNormal,\n    nomr: 'por confirmar', dirr: '8524 NW 61 ST', ciur: 'Miami',\n    estr: 'Florida', zipr: '33166', pair: 'USA', telr: '305-594-1100',\n    nAgencia: '00001', nprod: 'experto.col', producto: '16',\n  });\n}\n\nif (resultados.length === 0) {\n  return [{ json: { __sinGrupos: true, mensaje: 'No se encontraron WHRs para los casilleros recibidos', cookieNormal }}];\n}\n\nreturn resultados.map(r => ({ json: r }));\n"
      },
