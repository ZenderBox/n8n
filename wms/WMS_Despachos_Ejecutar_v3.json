    },
    {
      "parameters": {
        "jsCode": "const html = $input.item.json.data || '';\nconst grupo = $('Split Grupos').item.json;\nif (html.length < 500) return [{ json: { ...grupo, _parseOk: false, _error: 'guias.asp respuesta vacía' }}];\nfunction extractField(name) {\n  const m = html.match(new RegExp('name=\"' + name + '\"[^>]*value=\"([^\"]*)\"', 'i'));\n  return m ? m[1] : '';\n}\nconst casillero = extractField('casillero');\nconst casillero_id = extractField('casillero_id');\nconst guiaingreso = extractField('guiaingreso');\nconst fletes = extractField('fletes') || '0';\nconst Total = extractField('Total') || '0';\nconst adicionales = extractField('adicionales') || '0';\nconst h_adic_auto = extractField('h_adicionales_auto') || '';\nconst Val_Dif_Vol = extractField('Val_Dif_Vol') || '0';\nconst impuestotxt = extractField('impuestotxt') || '0.00';\nconst seguro = extractField('seguro') || '5.00';\nconst totalseguro = extractField('totalseguro') || '0.00';\nconst pesovolumetrico = extractField('pesovolumetrico') || '0';\nconst paquetesadjuntos = extractField('paquetesadjuntos') || '';\nconst formaPago = extractField('formaPago') || 'NP';\nconst nomd = extractField('nomd');\nconst dird = extractField('dird');\nconst des_nit = extractField('des_nit');\nconst ciudades = extractField('ciudades');\nconst ciudadesn = extractField('ciudadesn');\nconst paises = extractField('paises') || '1';\nconst paisesn = extractField('paisesn');\nconst zipd = extractField('zipd');\nconst teld = extractField('teld');\nconst emaild = extractField('emaild');\nconst celular_des = extractField('celular_des');\nconst rem_id = extractField('rem_id') || '';\nconst valdec = extractField('valdec') || grupo.valdec || '0';\nconst diferenciaPeso = extractField('diferenciaPeso') || '0';\nconst pesol2 = extractField('pesol2') || grupo.pesoTotal;\nconst pesovol = extractField('pesovol') || '0.00';\nif (!Total || Total === '0') return [{ json: { ...grupo, _parseOk: false, _error: 'SIN_TARIFA', casillero, guiaingreso }}];\nreturn [{ json: { ...grupo, _parseOk: true, guiaingreso, fletes, Total, adicionales, h_adic_auto, Val_Dif_Vol, impuestotxt, seguro, totalseguro, pesovolumetrico, paquetesadjuntos, formaPago, diferenciaPeso, pesol2, pesovol, valdec, casillero, casillero_id_real: casillero_id, nomd, dird, des_nit, ciudades, ciudadesn, paises, paisesn, zipd, teld, emaild, celular_des, rem_id }}];"
      },
