        "jsCode": "const headers = $input.item.json.headers || {};\nconst raw = headers['set-cookie'] || headers['Set-Cookie'] || [];\nconst parts = Array.isArray(raw) ? raw : [raw];\nconst cookieNormal = parts\n  .map(c => (typeof c === 'string' ? c.split(';')[0].trim() : ''))\n  .filter(Boolean).join('; ');\nif (!cookieNormal) throw new Error('Login fallido.');\n\nconst body = $('Webhook').item.json.body || {};\nconst casilleroIds = body.casillero_ids || [];\nif (casilleroIds.length === 0) throw new Error('No se recibieron casillero_ids');\n\nreturn [{ json: { cookieNormal, casilleroIds } }];\n"
