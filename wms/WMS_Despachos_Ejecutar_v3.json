    {
      "parameters": {
        "jsCode": "const resp = $input.item.json;\nconst grupo = $('Split Grupos').item.json;\nconst headers = resp.headers || {};\nconst location = headers['location'] || headers['Location'] || '';\nconst statusCode = resp.statusCode || 0;\nconst exito = statusCode === 302 && location.includes('salvado=1');\nconst idMatch = location.match(/id=(\\d+)/);\nconst guiaId = idMatch ? idMatch[1] : '';\nreturn [{ json: { ...grupo, _exito: exito, guiaId, location, statusCode, mensaje: exito ? `Despachado OK - Guía #${guiaId}` : `Error al guardar - Status:${statusCode}` }}];"
      },
