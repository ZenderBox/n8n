  toast(`Agencia "${name}" agregada`);
});

// ─────── Calculadora de Kg Pagados (modal) ───────
// Cuando son N pallets/tulas/piezas, el operario ingresa el peso de cada uno.
// Persiste sólo el TOTAL en kgPagados (los desgloses se guardan en el vuelo
// como `kgPagadosBreakdown` por si después queremos auditarlos).
function parsePiezasNum(piezas) {
  if (!piezas) return 1;
  const m = String(piezas).match(/(\d+)/);
  return m ? Math.max(1, parseInt(m[1], 10)) : 1;
}

function openCalcModal() {
  if (!currentVuelo) return;
  const v = currentVuelo;
  $('#calcMaster').textContent = v.master;
  // Default: cantidad = piezas del vuelo o 1
  const n = parsePiezasNum(v.piezas);
  $('#calcCount').value = n;
  // Si ya hay breakdown previo, lo precargamos. Si no, repartimos kgPagados / n
  const prev = v.kgPagadosBreakdown && v.kgPagadosBreakdown.length === n
    ? v.kgPagadosBreakdown
    : (v.kgPagados ? Array(n).fill(+(v.kgPagados / n).toFixed(2)) : Array(n).fill(0));
  renderCalcRows(n, prev);
  $('#calcBackdrop').classList.add('open');
  setTimeout(() => $('#calcRows input.kg').focus(), 50);
}

function renderCalcRows(n, values = []) {
  const rowsEl = $('#calcRows');
  let html = '';
  for (let i = 0; i < n; i++) {
    const val = values[i] != null ? values[i] : '';
    html += `
      <span class="idx">${i + 1}</span>
      <span class="lbl">Pieza / pallet</span>
      <input type="number" step="0.1" class="kg" data-i="${i}" value="${val || ''}" placeholder="0">
    `;
  }
  rowsEl.innerHTML = html;
  $$('#calcRows input.kg').forEach(inp => inp.addEventListener('input', updateCalcTotal));
  updateCalcTotal();
}

function updateCalcTotal() {
  const total = $$('#calcRows input.kg').reduce((s, i) => s + (parseFloat(i.value) || 0), 0);
  $('#calcTotal').textContent = fmtNum(total);
}

$('#totPagadosBtn').addEventListener('click', openCalcModal);
$('#calcGen').addEventListener('click', () => {
  const n = parseInt($('#calcCount').value, 10);
  if (!n || n < 1) { toast('Cantidad inválida'); return; }
  if (n > 200) { toast('Máximo 200 piezas'); return; }
  // Mantenemos los valores ya cargados que entren en el nuevo N
  const prev = $$('#calcRows input.kg').map(i => parseFloat(i.value) || 0);
  renderCalcRows(n, prev);
});
$('#calcCancel').addEventListener('click', () => $('#calcBackdrop').classList.remove('open'));
$('#calcSave').addEventListener('click', () => {
  if (!currentVuelo) return;
  const breakdown = $$('#calcRows input.kg').map(i => parseFloat(i.value) || 0);
  const total = breakdown.reduce((s, k) => s + k, 0);
  currentVuelo.kgPagados = total;
  currentVuelo.kgPagadosBreakdown = breakdown;
  renderTotales(currentVuelo);
  renderTable();
  $('#calcBackdrop').classList.remove('open');
  toast(`Kg pagados: ${fmtNum(total)} (${breakdown.length} pieza${breakdown.length>1?'s':''})`);
});
