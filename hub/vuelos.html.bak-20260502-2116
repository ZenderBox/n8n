function renderStatusGrid(v) {
  $('#statusGrid').innerHTML = STATUS_LIST.map(s => `
    <button class="status-opt ${v.status === s.id ? 'active' : ''}" data-status="${s.id}" ${s.trigger ? `data-trigger="${s.trigger}"` : ''}>
      <span class="dot" style="background:${s.dot}"></span>
      ${s.label}
    </button>
  `).join('');
  $$('#statusGrid .status-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      v.status = btn.dataset.status;
      renderStatusGrid(v);
      renderTable();
      toast(`Estatus actualizado a "${STATUS_MAP[v.status].label}"`);
    });
  });
}

function renderPesosTable(v) {
  const agencias = Object.keys(v.pesos).length ? Object.keys(v.pesos) : AGENCIAS_DEFAULT.slice(0, 6);
  agencias.forEach(a => { if (!v.pesos[a]) v.pesos[a] = [0, 0]; });

  const t = $('#pesosTable');
  let head = `<thead>
    <tr>
      <th rowspan="2" style="position:sticky;left:0;z-index:2;background:var(--zb-surface)">Agencia</th>
      ${agencias.map(a => `<th class="agency-h" colspan="${SERVICIOS.length}">${a}</th>`).join('')}
      <th rowspan="2" class="num">Total</th>
    </tr>
    <tr class="svcrow">
      ${agencias.map(() => SERVICIOS.map(s => `<th>${s}</th>`).join('')).join('')}
    </tr>
  </thead>`;

  // Una sola fila editable: kg por (agencia × servicio). Si quisiéramos múltiples masters por vuelo, sería N filas.
  const cells = agencias.map(a => {
    const [com, cas] = v.pesos[a] || [0,0];
    return `
      <td><input class="peso" data-ag="${a}" data-svc="0" type="number" step="0.1" value="${com || ''}"></td>
      <td><input class="peso" data-ag="${a}" data-svc="1" type="number" step="0.1" value="${cas || ''}"></td>
    `;
  }).join('');
  const totalRow = agencias.reduce((s,a) => s + (v.pesos[a][0]||0) + (v.pesos[a][1]||0), 0);

  t.innerHTML = head + `
    <tbody>
      <tr>
        <td class="label-cell">Kg por agencia</td>
        ${cells}
        <td class="num" id="rowTotal" style="background:#FBFBFB;font-weight:700;color:var(--zb-navy);padding:10px 12px">${fmtNum(totalRow)}</td>
      </tr>
    </tbody>
  `;

  $$('#pesosTable input.peso').forEach(inp => {
    inp.addEventListener('input', () => {
      const a = inp.dataset.ag, idx = +inp.dataset.svc;
      v.pesos[a][idx] = parseFloat(inp.value) || 0;
      const total = agencias.reduce((s,ag) => s + v.pesos[ag][0] + v.pesos[ag][1], 0);
      v.kgAgencias = total;
      $('#rowTotal').textContent = fmtNum(total);
      renderTotales(v);
      renderTable();
    });
  });

  renderTotales(v);
}

function renderTotales(v) {
  const agTot = v.kgAgencias || 0;
  const pgTot = v.kgPagados || 0;
  const diff  = pgTot - agTot;
  $('#totAgencias').textContent = fmtNum(agTot);
  $('#totPagados').textContent  = pgTot ? fmtNum(pgTot) : '—';
  const dEl = $('#totDiff');
  dEl.textContent = pgTot ? (diff>0?'+':'') + fmtNum(diff) : '—';
  dEl.className = 'v ' + (diff>0?'pos':diff<0?'neg':'');
  $('#totPiezas').textContent = v.piezas || '—';
}

