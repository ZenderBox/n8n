function mkVuelo(master, fecha, aerolinea, tipoEmbarque, factor, aeropuertoOrigen, aeropuertoDestino, consignatario, transportador, piezas, cons, status, kgAgencias, kgPagados, pesos) {
  return { master, fecha, aerolinea, tipoEmbarque, factor, aeropuertoOrigen, aeropuertoDestino, consignatario, transportador, piezas, cons, status, kgAgencias, kgPagados, pesos };
}

// Reconstruye el destino tipo "UPS - AAD - 0.40 ENEXCOL · BOG" desde sus partes
function composeDestino(v) {
  const parts = [v.aerolinea];
  if (v.tipoEmbarque) parts.push(v.tipoEmbarque);
  if (v.factor != null && v.factor !== '') parts.push(`${Number(v.factor).toFixed(2)} ${v.consignatario || ''}`.trim());
  else if (v.consignatario) parts.push(v.consignatario);
  let s = parts.filter(Boolean).join(' - ');
  if (v.aeropuertoDestino) s += ` · ${v.aeropuertoDestino}`;
  return s;
}

// ─────── Helpers ───────
const $  = (sel, ctx=document) => ctx.querySelector(sel);
const $$ = (sel, ctx=document) => Array.from(ctx.querySelectorAll(sel));
const fmt = n => (n == null || n === 0) ? '—' : Number(n).toLocaleString('es-CO', { maximumFractionDigits: 1 });
const fmtNum = n => Number(n||0).toLocaleString('es-CO', { maximumFractionDigits: 1 });
function pillFor(statusId) {
  const s = STATUS_MAP[statusId]; if (!s) return '';
  return `<span class="pill ${s.group}">${s.label}</span>`;
}
function carrierTag(c) {
  const cls = ({ UPS:'', ATLAS:'atlas', '7AIR':'air7', DHL:'dhl' })[c] || '';
  return `<span class="carrier-tag ${cls}">${c}</span>`;
}

// ─────── Render: tabla principal ───────
function renderTable() {
  const term = $('#searchInput').value.toLowerCase().trim();
  const fStatus = $('#filterStatus').value;
  const fAirport = $('#filterAirport').value;
  const fDest = $('#filterDest').value;
  const fCarrier = $('#filterCarrier').value;
  const fFrom = $('#filterFrom').value;
  const fTo = $('#filterTo').value;

  const weekOn = $('#chipWeek').classList.contains('on');
  const week = weekOn ? currentWeekRange() : null;

  const rows = VUELOS.filter(v => {
    if (fStatus  && v.status !== fStatus) return false;
    if (fAirport && v.aeropuertoDestino !== fAirport) return false;
    if (fDest    && v.consignatario !== fDest) return false;
    if (fCarrier && v.aerolinea !== fCarrier) return false;
    if (fFrom && v.fecha < fFrom) return false;
    if (fTo   && v.fecha > fTo) return false;
    if (week && (v.fecha < week.from || v.fecha > week.to)) return false;
    if (term) {
      const blob = `${v.master} ${composeDestino(v)} ${v.cons} ${v.piezas} ${v.tipoEmbarque||''} ${v.transportador||''}`.toLowerCase();
      if (!blob.includes(term)) return false;
    }
    return true;
  });

  const tbody = $('#vuelosBody');
  if (rows.length === 0) {
    tbody.innerHTML = '';
    $('#emptyState').style.display = 'block';
  } else {
    $('#emptyState').style.display = 'none';
    tbody.innerHTML = rows.map(v => {
      const diff = (v.kgPagados || 0) - (v.kgAgencias || 0);
      const diffCls = diff > 5 ? 'diff-pos' : diff < -5 ? 'diff-neg' : '';
      return `
        <tr data-master="${v.master}">
          <td class="master-cell">${v.master}</td>
          <td>${formatFecha(v.fecha)}</td>
          <td>${composeDestino(v)}</td>
          <td>${carrierTag(v.aerolinea)}</td>
          <td>${pillFor(v.status)}</td>
          <td class="num">${v.piezas || '—'}</td>
          <td class="num">${fmt(v.kgAgencias)}</td>
          <td class="num">${fmt(v.kgPagados)}</td>
          <td class="num ${diffCls}">${v.kgPagados ? (diff>0?'+':'') + fmtNum(diff) : '—'}</td>
        </tr>`;
    }).join('');
    $$('#vuelosBody tr').forEach(tr => tr.addEventListener('click', () => openDrawer(tr.dataset.master)));
  }
  renderKPIs();
}

function formatFecha(iso) {
  if (!iso) return '—';
  const [y,m,d] = iso.split('-');
  return `${d}/${m}/${y.slice(2)}`;
}

// Lunes-domingo de la semana en curso (ISO yyyy-mm-dd)
function currentWeekRange() {
  const now = new Date();
  const dow = (now.getDay() + 6) % 7; // 0 = lunes
  const mon = new Date(now); mon.setDate(now.getDate() - dow); mon.setHours(0,0,0,0);
  const sun = new Date(mon); sun.setDate(mon.getDate() + 6);
  const iso = d => d.toISOString().slice(0, 10);
  return { from: iso(mon), to: iso(sun) };
}

function renderKPIs() {
  const activos  = VUELOS.filter(v => v.status !== 'liquidado').length;
  const kg       = VUELOS.filter(v => !['liquidado'].includes(v.status)).reduce((s,v)=>s + (v.kgAgencias||0), 0);
  const reaj     = VUELOS.filter(v => v.status === 'reajustes').length;
  const diff     = VUELOS.reduce((s,v) => s + ((v.kgPagados||0) - (v.kgAgencias||0)), 0);
  $('#kpiActivos').textContent = activos;
  $('#kpiKg').textContent = fmtNum(kg);
  $('#kpiReaj').textContent = reaj;
  $('#kpiDiff').textContent = (diff>0?'+':'') + fmtNum(diff);
}

