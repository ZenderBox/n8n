<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Aéreo · Control de Vuelos · ZenderBox</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --zb-cyan:    #029ECB;
  --zb-cyan-dk: #007B9F;
  --zb-cyan-lt: #E6F5FB;
  --zb-navy:    #004B72;
  --zb-lime:    #CCD32A;
  --zb-lime-lt: #F7F8DE;
  --zb-ink:     #0D1C29;
  --zb-ink-700: #333333;
  --zb-ink-500: #666666;
  --zb-ink-300: #8A8A8A;
  --zb-ink-200: #B8B8B8;
  --zb-ink-100: #DBDBDB;
  --zb-line:    #E2E8EF;
  --zb-surface: #F6F6F6;
  --zb-white:   #FFFFFF;
  --zb-success: #008C31;
  --zb-success-bg: #E8F4ED;
  --zb-warn:    #B7791F;
  --zb-warn-bg: #FBF0DA;
  --zb-error:   #F32735;
  --zb-error-bg: #FBEAEC;
  --zb-gradient: linear-gradient(45deg, #029ECB 0%, #CCD32A 85%);
  --radius-sm:  6px;
  --radius-md:  10px;
  --radius-lg:  14px;
  --radius-pill: 99px;
  --shadow-sm:  0 1px 4px rgba(0,0,0,.06);
  --shadow-md:  0 4px 16px rgba(0,0,0,.08);
  --shadow-lg:  0 12px 32px rgba(39,39,39,.12);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
  background: var(--zb-surface);
  color: var(--zb-ink-700);
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

/* ───── Layout ───── */
main {
  margin-left: 220px;
  padding: 28px 32px 80px;
  max-width: 1600px;
}
@media (max-width: 768px) { main { margin-left: 0; padding: 18px 14px 60px; } }

/* ───── Page header ───── */
.page-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 22px; flex-wrap: wrap; }
.page-header h1 { font-size: 24px; font-weight: 800; color: var(--zb-navy); letter-spacing: -.4px; }
.page-header p  { font-size: 13px; color: var(--zb-ink-500); margin-top: 4px; font-weight: 500; }
.page-actions   { display: flex; gap: 8px; }

/* ───── Buttons ───── */
.btn {
  display: inline-flex; align-items: center; gap: 8px; border: 0;
  border-radius: var(--radius-sm); padding: 10px 16px;
  font: 700 13px/1 'Plus Jakarta Sans', sans-serif; cursor: pointer;
  text-decoration: none; transition: filter .15s, transform .1s, box-shadow .15s, background .15s, border-color .15s;
  white-space: nowrap;
}
.btn:active { transform: scale(.98); }
.btn-primary { background: var(--zb-gradient); color: #fff; }
.btn-primary:hover { filter: brightness(1.06); box-shadow: 0 4px 12px rgba(2,158,203,.25); }
.btn-secondary { background: var(--zb-cyan); color: #fff; }
.btn-secondary:hover { filter: brightness(1.06); }
.btn-ghost { background: var(--zb-white); color: var(--zb-navy); border: 1px solid var(--zb-line); }
.btn-ghost:hover { background: var(--zb-surface); border-color: var(--zb-cyan); color: var(--zb-cyan-dk); }
.btn-sm { padding: 7px 12px; font-size: 12px; }
.btn-icon-only { padding: 8px; }

/* ───── KPIs ───── */
.kpis { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 22px; }
@media (max-width: 980px) { .kpis { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px) { .kpis { grid-template-columns: 1fr; } }
.kpi {
  background: var(--zb-white); border: 1px solid var(--zb-line); border-radius: var(--radius-md);
  padding: 16px 18px; box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
}
.kpi-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--zb-ink-500); }
.kpi-value { font-size: 28px; font-weight: 800; color: var(--zb-navy); margin-top: 6px; line-height: 1.1; letter-spacing: -.5px; }
.kpi-sub   { font-size: 12px; color: var(--zb-ink-500); margin-top: 4px; font-weight: 500; }
.kpi-icon  {
  position: absolute; top: 14px; right: 14px; width: 32px; height: 32px;
  border-radius: var(--radius-sm); background: var(--zb-cyan-lt); color: var(--zb-cyan);
  display: flex; align-items: center; justify-content: center;
}
.kpi-icon svg { width: 16px; height: 16px; }
.kpi.alert .kpi-icon { background: var(--zb-warn-bg); color: var(--zb-warn); }
.kpi.alert .kpi-value { color: var(--zb-warn); }
.kpi.success .kpi-icon { background: var(--zb-success-bg); color: var(--zb-success); }

/* ───── Toolbar (filters) ───── */
.toolbar {
  background: var(--zb-white); border: 1px solid var(--zb-line); border-radius: var(--radius-md);
  padding: 14px; margin-bottom: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
}
.search-box { position: relative; flex: 1; min-width: 220px; }
.search-box svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--zb-ink-300); width: 14px; height: 14px; }
.search-box input { width: 100%; padding: 9px 12px 9px 34px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm); font: 500 13px 'Plus Jakarta Sans', sans-serif; background: var(--zb-white); color: var(--zb-ink-700); }
.search-box input:focus { outline: 0; border-color: var(--zb-cyan); box-shadow: 0 0 0 3px rgba(2,158,203,.12); }

.field { display: inline-flex; flex-direction: column; gap: 4px; }
.field label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--zb-ink-500); }
.field select, .field input[type="date"] {
  padding: 8px 10px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm);
  font: 500 13px 'Plus Jakarta Sans', sans-serif; background: var(--zb-white); color: var(--zb-ink-700); min-width: 120px;
}
.field select:focus, .field input[type="date"]:focus { outline: 0; border-color: var(--zb-cyan); }

.toolbar-spacer { flex: 1; }

/* ───── Vuelos table ───── */
.table-wrap {
  background: var(--zb-white); border: 1px solid var(--zb-line); border-radius: var(--radius-md);
  overflow: hidden; box-shadow: var(--shadow-sm);
}
table.vuelos { width: 100%; border-collapse: collapse; font-size: 13px; }
table.vuelos thead th {
  background: var(--zb-surface); text-align: left; font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .6px; color: var(--zb-ink-500);
  padding: 12px 14px; border-bottom: 1px solid var(--zb-line); white-space: nowrap;
}
table.vuelos tbody td {
  padding: 13px 14px; border-bottom: 1px solid var(--zb-line); vertical-align: middle;
  font-weight: 500; color: var(--zb-ink-700);
}
table.vuelos tbody tr { cursor: pointer; transition: background .12s; }
table.vuelos tbody tr:hover { background: #FAFCFE; }
table.vuelos tbody tr:last-child td { border-bottom: 0; }
.master-cell { font-weight: 700; color: var(--zb-navy); font-variant-numeric: tabular-nums; }
.num { text-align: right; font-variant-numeric: tabular-nums; }
.num.diff-pos { color: var(--zb-success); font-weight: 700; }
.num.diff-neg { color: var(--zb-error); font-weight: 700; }

.carrier-tag {
  display: inline-block; padding: 3px 8px; border-radius: var(--radius-sm);
  font-size: 11px; font-weight: 700; letter-spacing: .3px;
  background: var(--zb-cyan-lt); color: var(--zb-cyan-dk);
}
.carrier-tag.atlas { background: #FFF1E5; color: #B45309; }
.carrier-tag.air7  { background: #EEF0FF; color: #3D3F9E; }
.carrier-tag.dhl   { background: #FFF8DB; color: #92760E; }

/* ───── Status pill ───── */
.pill {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: var(--radius-pill);
  font-size: 11px; font-weight: 700; letter-spacing: .2px;
  border: 1px solid transparent; white-space: nowrap;
}
.pill::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.pill.transit  { background: var(--zb-cyan-lt); color: var(--zb-cyan-dk); }
.pill.warn     { background: var(--zb-warn-bg); color: var(--zb-warn); }
.pill.success  { background: var(--zb-success-bg); color: var(--zb-success); }
.pill.pending  { background: #F1F2F4; color: var(--zb-ink-500); }
.pill.blocked  { background: var(--zb-warn-bg); color: var(--zb-warn); border-color: #E9C77A; }
.pill.blocked::before { background: var(--zb-warn); animation: pulse 1.6s ease-in-out infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }

/* ───── Empty state ───── */
.empty {
  padding: 60px 20px; text-align: center; color: var(--zb-ink-500);
}
.empty svg { width: 48px; height: 48px; color: var(--zb-ink-200); margin-bottom: 12px; }
.empty h3 { font-size: 16px; font-weight: 700; color: var(--zb-ink-700); margin-bottom: 4px; }

/* ───── Drawer (peso por agencia) ───── */
.drawer-backdrop {
  position: fixed; inset: 0; background: rgba(13,28,41,.45); backdrop-filter: blur(2px);
  opacity: 0; pointer-events: none; transition: opacity .18s; z-index: 90;
}
.drawer-backdrop.open { opacity: 1; pointer-events: auto; }
.drawer {
  position: fixed; top: 0; right: 0; bottom: 0; width: min(1100px, 92vw);
  background: var(--zb-white); box-shadow: var(--shadow-lg); z-index: 100;
  transform: translateX(100%); transition: transform .25s cubic-bezier(.4,0,.2,1);
  display: flex; flex-direction: column;
}
.drawer.open { transform: translateX(0); }
.drawer-head {
  padding: 20px 24px 16px; border-bottom: 1px solid var(--zb-line);
  display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
}
.drawer-head h2 { font-size: 18px; font-weight: 800; color: var(--zb-navy); letter-spacing: -.2px; }
.drawer-head .meta { display: flex; gap: 16px; margin-top: 6px; flex-wrap: wrap; }
.drawer-head .meta span { font-size: 12px; color: var(--zb-ink-500); font-weight: 500; }
.drawer-head .meta strong { color: var(--zb-ink-700); font-weight: 700; }
.drawer-close {
  background: var(--zb-surface); border: 1px solid var(--zb-line); border-radius: var(--radius-sm);
  width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer; color: var(--zb-ink-500); transition: all .15s;
}
.drawer-close:hover { background: var(--zb-error-bg); color: var(--zb-error); border-color: var(--zb-error-bg); }

.drawer-body { padding: 20px 24px; overflow: auto; flex: 1; }
.drawer-section { margin-bottom: 24px; }
.drawer-section-title {
  font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px;
  color: var(--zb-ink-500); margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between;
}
.drawer-section-title button { font-size: 11px; }

/* status selector dentro del drawer */
.status-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 8px; }
.status-opt {
  border: 1px solid var(--zb-line); background: var(--zb-white); border-radius: var(--radius-sm);
  padding: 10px 12px; cursor: pointer; font-size: 12px; font-weight: 600; color: var(--zb-ink-700);
  display: flex; align-items: center; gap: 8px; transition: all .12s; text-align: left;
}
.status-opt:hover { border-color: var(--zb-cyan); background: var(--zb-cyan-lt); }
.status-opt.active { border-color: var(--zb-cyan); background: var(--zb-cyan-lt); color: var(--zb-cyan-dk); box-shadow: inset 0 0 0 1px var(--zb-cyan); }
.status-opt .dot { width: 8px; height: 8px; border-radius: 50%; }
.status-opt[data-trigger]::after {
  content: attr(data-trigger); font-size: 10px; font-weight: 600; color: var(--zb-warn);
  margin-left: auto; padding: 2px 6px; background: var(--zb-warn-bg); border-radius: var(--radius-sm);
}

/* tabla de pesos por agencia (grilla ancha estilo excel) */
.pesos-table-wrap { overflow-x: auto; border: 1px solid var(--zb-line); border-radius: var(--radius-md); }
table.pesos {
  border-collapse: collapse; min-width: 100%; font-size: 12px;
}
table.pesos thead th {
  position: sticky; top: 0; background: var(--zb-surface); z-index: 1;
  font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
  color: var(--zb-ink-500); padding: 10px 12px; text-align: left;
  border-bottom: 1px solid var(--zb-line); border-right: 1px solid var(--zb-line); white-space: nowrap;
}
table.pesos thead th:last-child { border-right: 0; }
table.pesos thead th.agency-h {
  text-align: center; background: var(--zb-cyan-lt); color: var(--zb-cyan-dk);
  font-weight: 700; border-bottom: 1px solid var(--zb-cyan);
}
table.pesos thead tr.svcrow th {
  background: #FAFCFE; font-size: 9px; padding: 6px 10px; color: var(--zb-ink-500);
  font-weight: 600;
}
table.pesos tbody td {
  padding: 0; border-bottom: 1px solid var(--zb-line); border-right: 1px solid var(--zb-line);
  vertical-align: middle;
}
table.pesos tbody td:last-child { border-right: 0; }
table.pesos tbody td.label-cell { padding: 10px 12px; font-weight: 600; color: var(--zb-ink-700); white-space: nowrap; background: var(--zb-surface); position: sticky; left: 0; z-index: 1; }
table.pesos input.peso {
  width: 100%; min-width: 70px; padding: 10px 12px; border: 0; background: transparent;
  font: 500 12px 'Plus Jakarta Sans', sans-serif; color: var(--zb-ink-700);
  text-align: right; font-variant-numeric: tabular-nums;
}
table.pesos input.peso:focus { outline: 0; background: var(--zb-cyan-lt); box-shadow: inset 0 0 0 2px var(--zb-cyan); }
table.pesos tbody tr.totals td { background: #FBFBFB; font-weight: 700; color: var(--zb-navy); padding: 10px 12px; font-variant-numeric: tabular-nums; text-align: right; }
table.pesos tbody tr.totals td.label-cell { text-align: left; }

.totales-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 14px; }
.totales-strip .tot { background: var(--zb-surface); border: 1px solid var(--zb-line); border-radius: var(--radius-sm); padding: 10px 12px; position: relative; }
.totales-strip .tot label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--zb-ink-500); }
.totales-strip .tot .v { font-size: 18px; font-weight: 800; color: var(--zb-navy); margin-top: 2px; font-variant-numeric: tabular-nums; }
.totales-strip .tot.diff .v.pos { color: var(--zb-success); }
.totales-strip .tot.diff .v.neg { color: var(--zb-error); }
.totales-strip .tot.editable { cursor: pointer; transition: all .15s; border: 1px dashed var(--zb-cyan); background: var(--zb-cyan-lt); }
.totales-strip .tot.editable:hover { background: #D6EEF7; box-shadow: var(--shadow-sm); }
.totales-strip .tot.editable .pencil { position: absolute; top: 8px; right: 8px; width: 14px; height: 14px; color: var(--zb-cyan-dk); opacity: .6; }
.totales-strip .tot.editable:hover .pencil { opacity: 1; }

/* Modal calculadora de kg pagados */
.calc-modal-backdrop { position: fixed; inset: 0; background: rgba(13,28,41,.45); backdrop-filter: blur(2px); display: none; align-items: center; justify-content: center; z-index: 130; }
.calc-modal-backdrop.open { display: flex; }
.calc-modal { background: var(--zb-white); border-radius: var(--radius-lg); width: min(440px, 92vw); box-shadow: var(--shadow-lg); overflow: hidden; display: flex; flex-direction: column; max-height: 90vh; }
.calc-modal-head { padding: 18px 22px 12px; border-bottom: 1px solid var(--zb-line); }
.calc-modal-head h3 { font-size: 16px; font-weight: 800; color: var(--zb-navy); }
.calc-modal-head p { font-size: 12px; color: var(--zb-ink-500); margin-top: 4px; font-weight: 500; }
.calc-modal-body { padding: 16px 22px; overflow: auto; }
.calc-controls { display: flex; gap: 8px; align-items: end; margin-bottom: 12px; }
.calc-controls .field { display: flex; flex-direction: column; gap: 4px; }
.calc-controls label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--zb-ink-500); }
.calc-controls input[type="number"] { width: 80px; padding: 8px 10px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm); font: 600 13px 'Plus Jakarta Sans', sans-serif; }
.calc-rows { display: grid; grid-template-columns: 38px 1fr 70px; gap: 8px 10px; align-items: center; }
.calc-rows .idx { font-size: 11px; font-weight: 700; color: var(--zb-ink-500); text-align: right; }
.calc-rows .lbl { font-size: 12px; color: var(--zb-ink-700); font-weight: 600; }
.calc-rows input.kg { padding: 8px 10px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm); font: 500 13px 'Plus Jakarta Sans', sans-serif; text-align: right; font-variant-numeric: tabular-nums; }
.calc-rows input.kg:focus { outline: 0; border-color: var(--zb-cyan); box-shadow: 0 0 0 3px rgba(2,158,203,.12); }
.calc-rows input.kg::placeholder { color: var(--zb-ink-200); font-style: italic; font-weight: 400; }
.calc-total { display: flex; justify-content: space-between; align-items: center; margin-top: 14px; padding: 12px 14px; background: var(--zb-cyan-lt); border-radius: var(--radius-sm); }
.calc-total .l { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--zb-cyan-dk); }
.calc-total .v { font-size: 22px; font-weight: 800; color: var(--zb-navy); font-variant-numeric: tabular-nums; }
.calc-modal-foot { padding: 12px 22px 16px; display: flex; justify-content: space-between; align-items: center; gap: 8px; background: var(--zb-surface); border-top: 1px solid var(--zb-line); }
.calc-modal-foot .left { font-size: 11px; color: var(--zb-ink-500); font-weight: 600; }

/* ───── Modal nuevo vuelo ───── */
.modal-backdrop {
  position: fixed; inset: 0; background: rgba(13,28,41,.45); backdrop-filter: blur(2px);
  display: none; align-items: center; justify-content: center; z-index: 110;
}
.modal-backdrop.open { display: flex; }
.modal {
  background: var(--zb-white); border-radius: var(--radius-lg); width: min(560px, 92vw);
  box-shadow: var(--shadow-lg); overflow: hidden;
  display: flex; flex-direction: column; max-height: 90vh;
}
.modal.bulk { width: min(1100px, 96vw); }
.modal-head { padding: 18px 22px 14px; border-bottom: 1px solid var(--zb-line); display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.modal-head h2 { font-size: 17px; font-weight: 800; color: var(--zb-navy); }
.modal-head p  { font-size: 12px; color: var(--zb-ink-500); margin-top: 4px; font-weight: 500; }
.modal-body { padding: 18px 22px; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; overflow: auto; }
.modal-body .field { display: flex; flex-direction: column; gap: 6px; }
.modal-body .field.full { grid-column: 1 / -1; }
.modal-body input, .modal-body select {
  padding: 10px 12px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm);
  font: 500 13px 'Plus Jakarta Sans', sans-serif; background: var(--zb-white); color: var(--zb-ink-700);
}
.modal-body input:focus, .modal-body select:focus { outline: 0; border-color: var(--zb-cyan); box-shadow: 0 0 0 3px rgba(2,158,203,.12); }
.modal-foot { padding: 12px 22px 16px; display: flex; justify-content: space-between; align-items: center; gap: 8px; background: var(--zb-surface); border-top: 1px solid var(--zb-line); }
.modal-foot .left { display: flex; gap: 8px; align-items: center; font-size: 12px; color: var(--zb-ink-500); font-weight: 600; }

/* segmented control: Individual / Bulk */
.segmented {
  display: inline-flex; padding: 3px; background: var(--zb-surface);
  border-radius: var(--radius-sm); border: 1px solid var(--zb-line);
}
.segmented button {
  border: 0; background: transparent; padding: 6px 14px; border-radius: 5px;
  font: 700 12px 'Plus Jakarta Sans', sans-serif; color: var(--zb-ink-500); cursor: pointer; transition: all .12s;
}
.segmented button.on { background: var(--zb-white); color: var(--zb-navy); box-shadow: var(--shadow-sm); }

/* bulk table */
.bulk-controls { display: flex; gap: 8px; align-items: end; padding: 0 22px 14px; flex-wrap: wrap; }
.bulk-controls .field { display: flex; flex-direction: column; gap: 4px; }
.bulk-controls .field label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--zb-ink-500); }
.bulk-controls input[type="number"] {
  width: 80px; padding: 8px 10px; border: 1px solid var(--zb-line); border-radius: var(--radius-sm);
  font: 600 13px 'Plus Jakarta Sans', sans-serif;
}
.bulk-table-wrap {
  overflow: auto; max-height: 50vh; border-top: 1px solid var(--zb-line);
  border-bottom: 1px solid var(--zb-line); margin: 0;
}
table.bulk-tbl {
  width: 100%; border-collapse: collapse; font-size: 12px;
}
table.bulk-tbl thead th {
  position: sticky; top: 0; background: var(--zb-surface); z-index: 1;
  font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
  color: var(--zb-ink-500); padding: 10px 10px; text-align: left;
  border-bottom: 1px solid var(--zb-line); white-space: nowrap;
}
table.bulk-tbl thead th.req::after { content: ' *'; color: var(--zb-error); }
table.bulk-tbl tbody td { padding: 0; border-bottom: 1px solid var(--zb-line); vertical-align: middle; }
table.bulk-tbl tbody td:first-child { padding: 8px 10px; color: var(--zb-ink-500); font-weight: 700; text-align: center; background: var(--zb-surface); }
table.bulk-tbl input, table.bulk-tbl select {
  width: 100%; padding: 9px 10px; border: 0; background: transparent;
  font: 500 12px 'Plus Jakarta Sans', sans-serif; color: var(--zb-ink-700);
}
table.bulk-tbl input:focus, table.bulk-tbl select:focus { outline: 0; background: var(--zb-cyan-lt); box-shadow: inset 0 0 0 2px var(--zb-cyan); }
table.bulk-tbl input.invalid { background: var(--zb-error-bg); }
table.bulk-tbl input::placeholder, .modal-body input::placeholder, .search-box input::placeholder {
  color: var(--zb-ink-200); font-style: italic; font-weight: 400;
}

/* ───── Quick filter chip ───── */
.chip-toggle {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 14px; border-radius: var(--radius-pill);
  border: 1px solid var(--zb-line); background: var(--zb-white);
  font: 700 12px 'Plus Jakarta Sans', sans-serif; color: var(--zb-ink-500);
  cursor: pointer; transition: all .15s; white-space: nowrap;
}
.chip-toggle:hover { border-color: var(--zb-cyan); color: var(--zb-cyan-dk); }
.chip-toggle.on {
  background: var(--zb-cyan-lt); color: var(--zb-cyan-dk);
  border-color: var(--zb-cyan);
}
.chip-toggle svg { width: 12px; height: 12px; }
table.bulk-tbl .row-del {
  border: 0; background: transparent; cursor: pointer; padding: 6px 10px; color: var(--zb-ink-300);
  border-radius: 4px; transition: all .12s;
}
table.bulk-tbl .row-del:hover { background: var(--zb-error-bg); color: var(--zb-error); }

/* ───── Toast ───── */
#toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
  background: var(--zb-navy); color: #fff; padding: 12px 18px; border-radius: var(--radius-sm);
  font-size: 13px; font-weight: 600; box-shadow: var(--shadow-md); opacity: 0; pointer-events: none;
  transition: all .25s; z-index: 200;
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<!-- Sidebar -->
<div id="wms-sidebar"></div>
<script src="sidebar.js"></script>

<main>
  <!-- Header -->
  <div class="page-header">
    <div>
      <h1>Control de Vuelos</h1>
      <p>Operación aérea · masters, pesos por agencia y estatus de despacho</p>
    </div>
    <div class="page-actions">
      <button class="btn btn-ghost btn-sm" id="btnRefresh" title="Refrescar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M3 12a9 9 0 0115-6.7L21 8M21 3v5h-5M21 12a9 9 0 01-15 6.7L3 16M3 21v-5h5"/></svg>
        Refrescar
      </button>
      <button class="btn btn-primary btn-sm" id="btnNuevoVuelo">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        Nuevo Vuelo
      </button>
    </div>
  </div>

  <!-- KPIs -->
  <div class="kpis">
    <div class="kpi">
      <div class="kpi-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg>
      </div>
      <div class="kpi-label">Vuelos Activos</div>
      <div class="kpi-value" id="kpiActivos">0</div>
      <div class="kpi-sub">en operación · todos los destinos</div>
    </div>
    <div class="kpi">
      <div class="kpi-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"/></svg>
      </div>
      <div class="kpi-label">Kg en Tránsito</div>
      <div class="kpi-value" id="kpiKg">0</div>
      <div class="kpi-sub">total agencias · vuelos no liquidados</div>
    </div>
    <div class="kpi alert">
      <div class="kpi-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg>
      </div>
      <div class="kpi-label">Esperando Reajustes</div>
      <div class="kpi-value" id="kpiReaj">0</div>
      <div class="kpi-sub">despacho bloqueado hasta planilla</div>
    </div>
    <div class="kpi success">
      <div class="kpi-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
      </div>
      <div class="kpi-label">Diferencia Acumulada</div>
      <div class="kpi-value" id="kpiDiff">0</div>
      <div class="kpi-sub">kg pagados − kg agencias</div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
      <input type="text" id="searchInput" placeholder="Buscar por master, guía, destino, consolidado…">
    </div>
    <div class="field">
      <label>Estatus</label>
      <select id="filterStatus"><option value="">Todos</option></select>
    </div>
    <div class="field">
      <label>Aeropuerto destino</label>
      <select id="filterAirport"><option value="">Todos</option></select>
    </div>
    <div class="field">
      <label>Consignatario</label>
      <select id="filterDest"><option value="">Todos</option></select>
    </div>
    <div class="field">
      <label>Aerolínea</label>
      <select id="filterCarrier"><option value="">Todas</option></select>
    </div>
    <div class="field">
      <label>Desde</label>
      <input type="date" id="filterFrom">
    </div>
    <div class="field">
      <label>Hasta</label>
      <input type="date" id="filterTo">
    </div>
    <button class="chip-toggle" id="chipWeek" type="button" title="Mostrar solo vuelos de esta semana (lun-dom)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Esta semana
    </button>
  </div>

  <!-- Tabla de vuelos -->
  <div class="table-wrap">
    <table class="vuelos">
      <thead>
        <tr>
          <th>Master</th>
          <th>Fecha</th>
          <th>Destino · Consignatario · Aeropuerto</th>
          <th>Aerolínea</th>
          <th>Estatus</th>
          <th class="num">Piezas</th>
          <th class="num">Kg Agencias</th>
          <th class="num">Kg Pagados</th>
          <th class="num">Diferencia</th>
        </tr>
      </thead>
      <tbody id="vuelosBody"></tbody>
    </table>
    <div class="empty" id="emptyState" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
      <h3>Sin resultados</h3>
      <p>Probá ajustando los filtros o el término de búsqueda.</p>
    </div>
  </div>
</main>

<!-- ───── Drawer (detalle vuelo + pesos) ───── -->
<div class="drawer-backdrop" id="drawerBackdrop"></div>
<aside class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer-head">
    <div>
      <h2 id="drawerTitle">—</h2>
      <div class="meta" id="drawerMeta"></div>
    </div>
    <button class="drawer-close" id="drawerClose" title="Cerrar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div class="drawer-body">
    <!-- Estatus -->
    <div class="drawer-section">
      <div class="drawer-section-title">
        <span>Estatus del Vuelo</span>
      </div>
      <div class="status-grid" id="statusGrid"></div>
    </div>

    <!-- Pesos por agencia -->
    <div class="drawer-section">
      <div class="drawer-section-title">
        <span>Pesos por Agencia</span>
        <button class="btn btn-ghost btn-sm" id="btnAddAgencia">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          Agregar agencia
        </button>
      </div>
      <div class="pesos-table-wrap">
        <table class="pesos" id="pesosTable"></table>
      </div>
      <div class="totales-strip">
        <div class="tot"><label>Total Kg Agencias</label><div class="v" id="totAgencias">0</div></div>
        <div class="tot editable" id="totPagadosBtn" title="Click para desglosar el peso por pieza/pallet">
          <svg class="pencil" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <label>Kg Pagados al Carrier</label>
          <div class="v" id="totPagados">0</div>
        </div>
        <div class="tot diff"><label>Diferencia</label><div class="v" id="totDiff">0</div></div>
        <div class="tot"><label>Piezas</label><div class="v" id="totPiezas">0</div></div>
      </div>
    </div>
  </div>
</aside>

<!-- ───── Modal calculadora kg pagados ───── -->
<div class="calc-modal-backdrop" id="calcBackdrop">
  <div class="calc-modal">
    <div class="calc-modal-head">
      <h3>Desglose de Kg Pagados al Carrier</h3>
      <p>Cargá el peso de cada pieza / pallet / tula. Se suman automáticamente.</p>
    </div>
    <div class="calc-modal-body">
      <div class="calc-controls">
        <div class="field">
          <label>Cantidad de piezas</label>
          <input type="number" id="calcCount" min="1" max="200" value="1">
        </div>
        <button class="btn btn-ghost btn-sm" id="calcGen" type="button">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M3 12a9 9 0 0115-6.7L21 8M21 3v5h-5"/></svg>
          Regenerar
        </button>
        <div style="flex:1"></div>
        <div style="font-size:11px;color:var(--zb-ink-500);font-weight:600">Vacíos = 0</div>
      </div>
      <div class="calc-rows" id="calcRows"></div>
      <div class="calc-total">
        <span class="l">Total kg pagados</span>
        <span class="v" id="calcTotal">0</span>
      </div>
    </div>
    <div class="calc-modal-foot">
      <div class="left" id="calcInfo">Master: <strong id="calcMaster">—</strong></div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" id="calcCancel">Cancelar</button>
        <button class="btn btn-primary btn-sm" id="calcSave">Guardar</button>
      </div>
    </div>
  </div>
</div>

<!-- ───── Modal nuevo vuelo ───── -->
<div class="modal-backdrop" id="modalBackdrop">
  <div class="modal" id="modalEl">
    <div class="modal-head">
      <div>
        <h2 id="modalTitle">Nuevo Vuelo</h2>
        <p id="modalDesc">Cargá la master y los datos básicos. Los pesos por agencia se llenan luego.</p>
      </div>
      <div class="segmented" id="modeToggle">
        <button class="on" data-mode="single">Individual</button>
        <button data-mode="bulk">Bulk</button>
      </div>
    </div>

    <!-- Modo Individual -->
    <div class="modal-body" id="modeSingle">
      <div class="field full">
        <label class="zb-label">Master (AWB) *</label>
        <input type="text" id="nvMaster" placeholder="406-XXXXXXXX">
      </div>
      <div class="field">
        <label class="zb-label">Fecha *</label>
        <input type="date" id="nvFecha">
      </div>
      <div class="field">
        <label class="zb-label">Aerolínea *</label>
        <select id="nvCarrier"></select>
      </div>
      <div class="field">
        <label class="zb-label">Tipo de embarque</label>
        <select id="nvTipo"></select>
      </div>
      <div class="field">
        <label class="zb-label">Factor</label>
        <input type="number" step="0.01" id="nvFactor" placeholder="0.40">
      </div>
      <div class="field">
        <label class="zb-label">Aeropuerto origen *</label>
        <select id="nvAeropOrig"></select>
      </div>
      <div class="field">
        <label class="zb-label">Aeropuerto destino *</label>
        <select id="nvAeropDest"></select>
      </div>
      <div class="field">
        <label class="zb-label">Consignatario *</label>
        <select id="nvDestinoCode"></select>
      </div>
      <div class="field">
        <label class="zb-label">Transportador</label>
        <select id="nvTransp"></select>
      </div>
      <div class="field">
        <label class="zb-label">Estatus *</label>
        <select id="nvStatus"></select>
      </div>
      <div class="field">
        <label class="zb-label">Piezas</label>
        <input type="text" id="nvPiezas" placeholder="ej. 4 PALLETS">
      </div>
      <div class="field full">
        <label class="zb-label">Consolidados</label>
        <input type="text" id="nvCons" placeholder="ej. CAS xxxx - AGE xxxx">
      </div>
    </div>

    <!-- Modo Bulk -->
    <div id="modeBulk" style="display:none">
      <div class="bulk-controls">
        <div class="field">
          <label>Cantidad de vuelos</label>
          <input type="number" id="bulkCount" min="1" max="50" value="5">
        </div>
        <button class="btn btn-ghost btn-sm" id="bulkGen">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
          Generar filas
        </button>
        <div class="toolbar-spacer" style="flex:1"></div>
        <div style="font-size:11px;color:var(--zb-ink-500);font-weight:600">* obligatorios · vacíos se ignoran</div>
      </div>
      <div class="bulk-table-wrap">
        <table class="bulk-tbl" id="bulkTable">
          <thead>
            <tr>
              <th style="width:34px">#</th>
              <th class="req">Master</th>
              <th class="req">Fecha</th>
              <th class="req">Aerolínea</th>
              <th>Tipo</th>
              <th>Factor</th>
              <th class="req">Aerop. dest</th>
              <th class="req">Consignatario</th>
              <th>Transp.</th>
              <th>Estatus</th>
              <th>Piezas</th>
              <th>Consolidados</th>
              <th style="width:36px"></th>
            </tr>
          </thead>
          <tbody id="bulkBody"></tbody>
        </table>
      </div>
    </div>

    <div class="modal-foot">
      <div class="left" id="modalFootInfo"></div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" id="nvCancel">Cancelar</button>
        <button class="btn btn-primary btn-sm" id="nvSave">Crear vuelo</button>
      </div>
    </div>
  </div>
</div>

<div id="toast"></div>

