// ── Save ──
$('#nvSave').addEventListener('click', () => {
  if (modalMode === 'single') {
    const m = $('#nvMaster').value.trim();
    const f = $('#nvFecha').value;
    const dest = $('#nvDestinoCode').value;
    const aerOrig = $('#nvAeropOrig').value;
    const aerDest = $('#nvAeropDest').value;
    const st = $('#nvStatus').value;
    if (!m)       { toast('Falta el master'); return; }
    if (!f)       { toast('Falta la fecha'); return; }
    if (!aerOrig) { toast('Falta el aeropuerto origen'); return; }
    if (!aerDest) { toast('Falta el aeropuerto destino'); return; }
    if (!dest)    { toast('Falta el consignatario'); return; }
    if (!st)      { toast('Falta el estatus'); return; }
    if (VUELOS.some(v => v.master === m)) { toast('Ya existe ese master'); return; }
    VUELOS.unshift(mkVuelo(
      m, f, $('#nvCarrier').value, $('#nvTipo').value,
      parseFloat($('#nvFactor').value) || null,
      aerOrig, aerDest, dest, $('#nvTransp').value || null,
      $('#nvPiezas').value, $('#nvCons').value, st, 0, 0, {}
    ));
    $('#modalBackdrop').classList.remove('open');
    ['nvMaster','nvPiezas','nvCons','nvFactor'].forEach(id => $('#'+id).value = '');
    renderTable();
    toast('Vuelo creado');
    setTimeout(() => openDrawer(m), 200);
  } else {
    // bulk
    const rows = $$('#bulkBody tr');
    if (!rows.length) { toast('No hay filas para crear'); return; }
    const errors = [];
    const created = [];
    rows.forEach((tr, i) => {
      const m = tr.querySelector('.b-master').value.trim();
      const f = tr.querySelector('.b-fecha').value;
      const car = tr.querySelector('.b-carrier').value;
      const aero = tr.querySelector('.b-aerop').value;
      const dest = tr.querySelector('.b-destino').value;
      // marcar inválidas
      tr.querySelectorAll('input.invalid, select.invalid').forEach(el => el.classList.remove('invalid'));
      let bad = false;
      if (!m)    { tr.querySelector('.b-master').classList.add('invalid'); bad = true; }
      else if (VUELOS.some(v => v.master === m) || created.some(c => c.master === m)) {
        tr.querySelector('.b-master').classList.add('invalid'); errors.push(`Fila ${i+1}: master duplicado`); bad = true;
      }
      if (!f)    { tr.querySelector('.b-fecha').classList.add('invalid'); bad = true; }
      if (!aero) { tr.querySelector('.b-aerop').classList.add('invalid'); bad = true; }
      if (!dest) { tr.querySelector('.b-destino').classList.add('invalid'); bad = true; }
      if (bad) { errors.push(`Fila ${i+1}: completá los obligatorios`); return; }
      created.push(mkVuelo(
        m, f, car,
        tr.querySelector('.b-tipo').value,
        parseFloat(tr.querySelector('.b-factor').value) || null,
        AEROPUERTO_ORIGEN_DEFAULT,
        aero,
        dest,
        tr.querySelector('.b-transp').value || null,
        tr.querySelector('.b-piezas').value,
        tr.querySelector('.b-cons').value,
        tr.querySelector('.b-status').value || 'sin-estatus',
        0, 0, {}
      ));
    });
    if (errors.length) { toast(errors[0]); return; }
    created.reverse().forEach(v => VUELOS.unshift(v));
    $('#modalBackdrop').classList.remove('open');
    $('#bulkBody').innerHTML = '';
    renderTable();
    toast(`${created.length} vuelo${created.length>1?'s':''} creado${created.length>1?'s':''}`);
  }
});
$('#modalBackdrop').addEventListener('click', e => { if (e.target.id === 'modalBackdrop') $('#modalBackdrop').classList.remove('open'); });

// ─────── Listeners ───────
['searchInput','filterStatus','filterAirport','filterDest','filterCarrier','filterFrom','filterTo'].forEach(id => {
  $('#'+id).addEventListener('input', renderTable);
  $('#'+id).addEventListener('change', renderTable);
});
$('#chipWeek').addEventListener('click', () => {
  $('#chipWeek').classList.toggle('on');
  renderTable();
});
$('#drawerClose').addEventListener('click', closeDrawer);
$('#drawerBackdrop').addEventListener('click', closeDrawer);
$('#btnRefresh').addEventListener('click', () => { renderTable(); toast('Actualizado'); });
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if ($('#calcBackdrop').classList.contains('open'))      $('#calcBackdrop').classList.remove('open');
    else if ($('#modalBackdrop').classList.contains('open')) $('#modalBackdrop').classList.remove('open');
    else if ($('#drawer').classList.contains('open'))        closeDrawer();
  }
});

// ─────── Toast ───────
function toast(msg) {
  const t = $('#toast'); t.textContent = msg; t.classList.add('show');
  clearTimeout(t._h); t._h = setTimeout(() => t.classList.remove('show'), 2200);
}

// ─────── Init ───────
populateModalSelects();
populateFilters();
renderTable();
</script>

</body>
