<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Growth — ZenderBox</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
<style>
  /* ── ZenderBox DS · white-first · Ref: 09-Design-System/colors_and_type.css ── */
  :root {
    --zb-cyan:       #029ECB;
    --zb-cyan-dark:  #007B9F;
    --zb-cyan-soft:  rgba(2,158,203,.10);
    --zb-navy:       #004B72;
    --zb-lime:       #CCD32A;
    --zb-lime-soft:  rgba(204,211,42,.18);
    --zb-gradient:   linear-gradient(45deg, #029ECB 0%, #CCD32A 85%);
    --zb-gradient-soft: linear-gradient(135deg, rgba(2,158,203,.06) 0%, rgba(204,211,42,.10) 100%);

    --zb-ink-900: #1F1F1F;
    --zb-ink-700: #333333;
    --zb-ink-500: #666666;
    --zb-ink-300: #8A8A8A;
    --zb-ink-200: #B8B8B8;
    --zb-ink-100: #DBDBDB;
    --zb-ink-50:  #F6F6F6;
    --zb-paper:   #FFFFFF;

    --zb-success:    #008C31;
    --zb-success-bg: #F1F6F5;
    --zb-error:      #F32735;
    --zb-error-bg:   #F4E8E9;
    --zb-warn:       #7A6A00;
    --zb-warn-bg:    rgba(204,211,42,.18);

    --zb-radius-sm: 8px;
    --zb-radius-md: 10px;
    --zb-radius-lg: 16px;
    --zb-radius-pill: 99px;
    --zb-shadow-sm: 0 2px 4px 0 rgba(39,39,39,.10);
    --zb-shadow-md: 0 4px 12px 0 rgba(39,39,39,.08);
    --zb-shadow-brand: 0 8px 32px -12px rgba(2,158,203,.30);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    height: 100%;
    font-family: 'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
    background: var(--zb-ink-50);
    color: var(--zb-ink-700);
    font-size: 14px;
    -webkit-font-smoothing: antialiased;
  }
  ::selection { background: var(--zb-cyan-soft); }

  /* ── Topbar ── */
  .topbar {
    display: flex; align-items: center; gap: 16px;
    padding: 14px 24px;
    margin-left: 220px;
    background: var(--zb-paper);
    border-bottom: 1px solid var(--zb-ink-100);
    position: sticky; top: 0; z-index: 100;
  }
  .topbar-icon {
    width: 36px; height: 36px;
    background: var(--zb-gradient);
    border-radius: var(--zb-radius-md);
    display: inline-flex; align-items: center; justify-content: center;
    color: white;
    box-shadow: var(--zb-shadow-brand);
  }
  .topbar-icon svg { width: 18px; height: 18px; stroke-width: 2.2; }
  .topbar-title { font-size: 15px; font-weight: 700; color: var(--zb-ink-900); letter-spacing: -.01em; }
  .topbar-sub { font-size: 12px; color: var(--zb-ink-500); font-weight: 500; margin-top: 2px; }
  .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 12px; }
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px;
    border-radius: var(--zb-radius-pill);
    font-size: 11px; font-weight: 700;
    background: var(--zb-warn-bg);
    color: var(--zb-warn);
    letter-spacing: .03em; text-transform: uppercase;
  }
  .pill .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--zb-warn); animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    border: none; border-radius: var(--zb-radius-sm);
    padding: 10px 16px; font-size: 13px;
    font-weight: 700; cursor: pointer;
    font-family: inherit;
    transition: filter .15s, transform .1s, background .15s, border-color .15s, color .15s;
    white-space: nowrap;
  }
  .btn svg { width: 14px; height: 14px; }
  .btn-secondary {
    background: var(--zb-ink-50);
    border: 1px solid var(--zb-ink-100);
    color: var(--zb-ink-700);
  }
  .btn-secondary:hover {
    background: var(--zb-paper);
    border-color: var(--zb-cyan-dark);
    color: var(--zb-cyan-dark);
  }

  /* ── Main ── */
  .main {
    margin-left: 220px;
    padding: 24px 28px 60px;
    max-width: 1480px;
  }

  /* ── Hero gradient strip ── */
  .hero {
    background: var(--zb-gradient);
    border-radius: var(--zb-radius-lg);
    padding: 28px 32px;
    margin-bottom: 24px;
    color: white;
    box-shadow: var(--zb-shadow-brand);
    position: relative; overflow: hidden;
  }
  .hero::after {
    content: ''; position: absolute; top: -40%; right: -10%;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-eyebrow {
    font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    opacity: .85;
  }
  .hero-title {
    font-size: 26px; font-weight: 800; letter-spacing: -.02em; line-height: 32px;
    margin-top: 4px;
  }
  .hero-sub {
    font-size: 13px; opacity: .9; margin-top: 6px; font-weight: 500;
  }
  .hero-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    margin-top: 24px;
    position: relative; z-index: 1;
  }
  .hero-stat {
    background: rgba(255,255,255,.14);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,.18);
    border-radius: var(--zb-radius-md);
    padding: 16px 18px;
  }
  .hero-stat .label {
    font-size: 10px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    opacity: .85; margin-bottom: 6px;
    display: flex; align-items: center; gap: 6px;
  }
  .hero-stat .label svg { width: 12px; height: 12px; }
  .hero-stat .value { font-size: 32px; font-weight: 800; letter-spacing: -.02em; line-height: 36px; }
  .hero-stat .sub { font-size: 11px; opacity: .8; margin-top: 4px; font-weight: 500; }

  /* ── Banner v1 ── */
  .banner {
    background: var(--zb-paper);
    border: 1px solid var(--zb-ink-100);
    border-left: 3px solid var(--zb-lime);
    border-radius: var(--zb-radius-md);
    padding: 14px 18px;
    margin-bottom: 24px;
    display: flex; align-items: center; gap: 12px;
    font-size: 13px; color: var(--zb-ink-700); font-weight: 500;
  }
  .banner-ico {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: var(--zb-radius-sm);
    background: var(--zb-lime-soft);
    color: var(--zb-warn);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .banner-ico svg { width: 16px; height: 16px; }
  .banner strong { color: var(--zb-ink-900); font-weight: 700; }
  .banner code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; background: var(--zb-ink-50); color: var(--zb-cyan-dark); padding: 1px 6px; border-radius: 4px; font-size: 12px; }

  /* ── Tabs ── */
  .tabs {
    display: flex; gap: 2px;
    background: var(--zb-paper);
    border: 1px solid var(--zb-ink-100);
    border-radius: var(--zb-radius-md);
    padding: 4px;
    margin-bottom: 20px;
    width: fit-content;
  }
  .tab {
    background: transparent; border: none;
    padding: 10px 18px;
    font-family: inherit; font-size: 13px; font-weight: 600;
    color: var(--zb-ink-500);
    border-radius: var(--zb-radius-sm);
    cursor: pointer;
    transition: all .15s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .tab svg { width: 14px; height: 14px; }
  .tab:hover { color: var(--zb-cyan-dark); background: var(--zb-ink-50); }
  .tab.active {
    background: var(--zb-cyan-soft);
    color: var(--zb-cyan-dark);
    font-weight: 700;
  }
  .tab-panel { display: none; animation: fadeIn .25s ease; }
  .tab-panel.active { display: block; }
  @keyframes fadeIn { from{opacity:0; transform:translateY(4px)} to{opacity:1; transform:none} }

  /* ── Section title ── */
  .section-title {
    font-size: 11px; font-weight: 800; color: var(--zb-ink-500);
    letter-spacing: .12em; text-transform: uppercase;
    margin: 0 0 14px 4px;
    display: flex; align-items: center; gap: 8px;
  }
  .section-title svg { width: 14px; height: 14px; color: var(--zb-cyan); }

  /* ── Grid ── */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }

  /* ── Card ── */
  .card {
    background: var(--zb-paper);
    border: 1px solid var(--zb-ink-100);
    border-radius: var(--zb-radius-md);
    overflow: hidden;
  }
  .card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--zb-ink-100);
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px;
  }
  .card-title {
    font-size: 14px; font-weight: 700; color: var(--zb-ink-900);
    display: flex; align-items: center; gap: 8px;
    letter-spacing: -.01em;
  }
  .card-title .ico {
    width: 28px; height: 28px;
    background: var(--zb-cyan-soft);
    color: var(--zb-cyan);
    border-radius: var(--zb-radius-sm);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .card-title .ico svg { width: 14px; height: 14px; }
  .card-body { padding: 18px 20px; }
  .card-empty {
    padding: 36px 24px;
    text-align: center;
    color: var(--zb-ink-500);
  }
  .card-empty .ico-big {
    width: 56px; height: 56px;
    background: var(--zb-gradient-soft);
    border-radius: var(--zb-radius-pill);
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
    color: var(--zb-cyan);
  }
  .card-empty .ico-big svg { width: 28px; height: 28px; }
  .card-empty .title { font-size: 14px; font-weight: 700; color: var(--zb-ink-900); margin-bottom: 6px; }
  .card-empty .desc { font-size: 13px; color: var(--zb-ink-500); font-weight: 500; max-width: 380px; margin: 0 auto; line-height: 18px; }
  .card-empty .desc strong { color: var(--zb-ink-700); font-weight: 700; }

  /* ── Bar chart row ── */
  .bar-row {
    display: grid;
    grid-template-columns: 130px 50px 50px 1fr;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--zb-ink-50);
    font-size: 13px;
  }
  .bar-row:last-child { border-bottom: none; }
  .bar-row .lbl { font-weight: 600; color: var(--zb-ink-700); display: flex; align-items: center; gap: 8px; }
  .bar-row .num { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-weight: 700; color: var(--zb-ink-900); text-align: right; font-size: 13px; }
  .bar-row .pct { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-weight: 500; color: var(--zb-ink-500); text-align: right; font-size: 12px; }
  .bar-track {
    height: 8px;
    background: var(--zb-ink-50);
    border-radius: var(--zb-radius-pill);
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    border-radius: var(--zb-radius-pill);
    transition: width .4s cubic-bezier(.16,1,.3,1);
  }
  .bar-fill.cyan { background: var(--zb-cyan); }
  .bar-fill.lime { background: var(--zb-lime); }
  .bar-fill.gradient { background: var(--zb-gradient); }
  .bar-fill.success { background: var(--zb-success); }
  .bar-fill.error { background: var(--zb-error); }
  .bar-fill.gray { background: var(--zb-ink-300); }

  /* ── Table inside card ── */
  .table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .table th {
    padding: 12px 20px;
    text-align: left;
    font-size: 11px; font-weight: 700; color: var(--zb-ink-500);
    text-transform: uppercase; letter-spacing: .04em;
    background: var(--zb-ink-50);
    border-bottom: 1px solid var(--zb-ink-100);
  }
  .table th.right { text-align: right; }
  .table td {
    padding: 12px 20px;
    border-bottom: 1px solid var(--zb-ink-100);
    color: var(--zb-ink-700);
    font-weight: 500;
    vertical-align: middle;
  }
  .table tr:last-child td { border-bottom: none; }
  .table tbody tr:hover td { background: var(--zb-ink-50); }
  .table .right { text-align: right; }
  .table .num {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-weight: 700; color: var(--zb-ink-900);
  }

  /* ── Badge ── */
  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px;
    border-radius: var(--zb-radius-pill);
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: .04em;
    white-space: nowrap;
  }
  .badge-dot { width: 6px; height: 6px; border-radius: 50%; }
  .badge.success    { background: var(--zb-success-bg); color: var(--zb-success); }
  .badge.success .badge-dot    { background: var(--zb-success); }
  .badge.cyan       { background: var(--zb-cyan-soft);  color: var(--zb-cyan-dark); }
  .badge.cyan .badge-dot       { background: var(--zb-cyan); }
  .badge.lime       { background: var(--zb-lime-soft);  color: var(--zb-warn); }
  .badge.lime .badge-dot       { background: var(--zb-lime); }
  .badge.error      { background: var(--zb-error-bg);   color: var(--zb-error); }
  .badge.error .badge-dot      { background: var(--zb-error); }
  .badge.gray       { background: var(--zb-ink-50);     color: var(--zb-ink-500); border: 1px solid var(--zb-ink-100); }
  .badge.gray .badge-dot       { background: var(--zb-ink-300); }
  .badge.navy       { background: rgba(0,75,114,.10);   color: var(--zb-navy); }
  .badge.navy .badge-dot       { background: var(--zb-navy); }

  /* ── Welcome row in calidad ── */
  .welcome-text {
    max-width: 360px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    color: var(--zb-ink-700); font-weight: 500;
  }

  /* ── Footer meta ── */
  .footer-meta {
    margin-top: 32px; padding-top: 16px;
    border-top: 1px solid var(--zb-ink-100);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 11px; font-weight: 500; color: var(--zb-ink-300);
  }
  .footer-meta code { font-family: ui-monospace, 'SF Mono', Menlo, monospace; color: var(--zb-ink-500); }

  /* ── Ranking bar (campaign perf) ── */
  .perf-row {
    display: grid;
    grid-template-columns: 1fr 70px 70px 1fr 90px;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--zb-ink-100);
    font-size: 13px;
  }
  .perf-row:last-child { border-bottom: none; }
  .perf-name { font-weight: 700; color: var(--zb-ink-900); display: flex; align-items: center; gap: 8px; }
  .perf-name .rank { width: 22px; height: 22px; border-radius: 50%; background: var(--zb-ink-50); color: var(--zb-ink-500); font-size: 11px; font-weight: 800; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .perf-name.top1 .rank { background: var(--zb-gradient); color: white; }
  .perf-name.top2 .rank { background: var(--zb-cyan-soft); color: var(--zb-cyan-dark); }
  .perf-num  { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-weight: 700; color: var(--zb-ink-900); text-align: right; }
  .perf-num.muted { color: var(--zb-ink-500); font-weight: 600; }

  @media (max-width: 1100px) {
    .grid-2 { grid-template-columns: 1fr; }
    .hero-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .topbar, .main { margin-left: 0; }
    .hero-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div id="wms-sidebar"></div>

<div class="topbar">
  <div class="topbar-icon"><i data-lucide="trending-up"></i></div>
  <div>
    <div class="topbar-title">Growth</div>
    <div class="topbar-sub">Marketing &middot; atribución &middot; calidad de leads</div>
  </div>
  <div class="topbar-right">
    <span class="pill"><span class="dot"></span>v1 &middot; static</span>
    <button class="btn btn-secondary" onclick="alert('Backend live en construcción — v2 conecta PG + Meta API')">
      <i data-lucide="refresh-ccw"></i>Actualizar
    </button>
  </div>
</div>

<div class="main">

  <!-- ═════════ HERO ═════════ -->
  <div class="hero">
    <div class="hero-eyebrow">Provincial Abril 2026 · Día 2 / 7</div>
    <div class="hero-title">Provincial está convirtiendo bien.</div>
    <div class="hero-sub">$1.77 por conversación · 42 conv en 2 días · 2da campaña más eficiente del mes.</div>
    <div class="hero-grid">
      <div class="hero-stat">
        <div class="label"><i data-lucide="message-square"></i>Conversaciones 28-29 abr</div>
        <div class="value">70</div>
        <div class="sub">14 + 56 leads CTM</div>
      </div>
      <div class="hero-stat">
        <div class="label"><i data-lucide="dollar-sign"></i>Spend Provincial 7d</div>
        <div class="value">$84</div>
        <div class="sub">de $350 budget · 24% utilizado</div>
      </div>
      <div class="hero-stat">
        <div class="label"><i data-lucide="target"></i>Cost / conversación</div>
        <div class="value">$1.77</div>
        <div class="sub">meta &lt; $2 · cumple</div>
      </div>
      <div class="hero-stat">
        <div class="label"><i data-lucide="sparkles"></i>Interés real (IA)</div>
        <div class="value">60%</div>
        <div class="sub">de leads nuevos del día</div>
      </div>
    </div>
  </div>

  <!-- ═════════ BANNER ═════════ -->
  <div class="banner">
    <div class="banner-ico"><i data-lucide="info"></i></div>
    <div>
      <strong>v1 estática.</strong> Datos del análisis IA Clasificación 28-29 abr 2026 GMT-5.
      Backend live se conecta en v2 (PG <code>ia_clasificacion</code> + <code>meta_atribuciones</code> + Meta Ads API).
    </div>
  </div>

  <!-- ═════════ TABS ═════════ -->
  <div class="tabs">
    <button class="tab active" data-panel="overview"  onclick="setTab('overview')"><i data-lucide="layout-dashboard"></i>Overview</button>
    <button class="tab"        data-panel="campanas"  onclick="setTab('campanas')"><i data-lucide="megaphone"></i>Campañas</button>
    <button class="tab"        data-panel="calidad"   onclick="setTab('calidad')"><i data-lucide="brain"></i>Calidad IA</button>
    <button class="tab"        data-panel="atribucion" onclick="setTab('atribucion')"><i data-lucide="git-branch"></i>Atribución</button>
  </div>

  <!-- ═════════ OVERVIEW ═════════ -->
  <div class="tab-panel active" id="panel-overview">

    <div class="grid-2">

      <!-- Calidad IA -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <span class="ico"><i data-lucide="brain"></i></span>
            Distribución calidad · 28 abr
          </div>
          <span class="badge gray"><span class="badge-dot"></span>14 procesados</span>
        </div>
        <div class="card-body">
          <div class="bar-row">
            <span class="lbl"><span class="badge success"><span class="badge-dot"></span>interés real</span></span>
            <span class="num">6</span>
            <span class="pct">43%</span>
            <div class="bar-track"><div class="bar-fill success" style="width:43%"></div></div>
          </div>
          <div class="bar-row">
            <span class="lbl"><span class="badge cyan"><span class="badge-dot"></span>ya cliente</span></span>
            <span class="num">4</span>
            <span class="pct">29%</span>
            <div class="bar-track"><div class="bar-fill cyan" style="width:29%"></div></div>
          </div>
          <div class="bar-row">
            <span class="lbl"><span class="badge lime"><span class="badge-dot"></span>no califica</span></span>
            <span class="num">2</span>
            <span class="pct">14%</span>
            <div class="bar-track"><div class="bar-fill lime" style="width:14%"></div></div>
          </div>
          <div class="bar-row">
            <span class="lbl"><span class="badge error"><span class="badge-dot"></span>solo bono</span></span>
            <span class="num">1</span>
            <span class="pct">7%</span>
            <div class="bar-track"><div class="bar-fill error" style="width:7%"></div></div>
          </div>
          <div class="bar-row">
            <span class="lbl"><span class="badge gray"><span class="badge-dot"></span>spam / error</span></span>
            <span class="num">1</span>
            <span class="pct">7%</span>
            <div class="bar-track"><div class="bar-fill gray" style="width:7%"></div></div>
          </div>
        </div>
      </div>

      <!-- Performance ranking -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">
            <span class="ico"><i data-lucide="bar-chart-3"></i></span>
            Performance campañas · 7d
          </div>
          <span class="badge cyan"><span class="badge-dot"></span>Meta Ads</span>
