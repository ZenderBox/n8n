    {
      "id": "8a472896-1694-4a81-8766-8d3afe902422",
      "name": "Motor de Reglas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        300
      ],
      "parameters": {
        "jsCode": "\n// ══════════════════════════════════════════════════════\n// MOTOR DE REGLAS - WMS Despachos Colombia v2\n// ══════════════════════════════════════════════════════\nconst REGLAS = {\n  posiciones_validas:    ['Z2-', 'Z7-'],\n  contenido_bloqueado:   ['ingreso cubiq', 'celular', 'imei'],\n  contenido_dg:          ['dg', 'un'],\n  contenido_cr:          ['costa rica', 'colon [san jose]'],\n  agencia_cr:            ['zenderbox costa rica', 'zenderbox cr'],\n  peso_minimo:           0.01,\n  valor_declarado_max:   200,\n  casilleros_bloqueados: ['ZB-114665'],\n  casilleros_bloqueados_id: ['17771'],\n};\n\nconst html = $input.item.json.data || '';\nconst cookieNormal = $('Extraer Cookies y IDs').item.json.cookieNormal;\nconst casilleroIds = $('Extraer Cookies y IDs').item.json.casilleroIds || [];\n\nif (html.length < 500) throw new Error('HTML muy pequeño - error de sesión');\n\nconst rows = [];\nconst whrPattern = /<span class=\"titulos\">(WHR\\d+)<\\/span>/g;\nlet match;\n\nwhile ((match = whrPattern.exec(html)) !== null) {\n  const whr = match[1];\n  const start = match.index;\n  const block = html.substring(start, start + 3000);\n\n  const midM = block.match(/manifiesto_id\" value=\"(\\d+)\"/);\n  const manifestoId = midM ? midM[1] : '';\n\n  const creaM = block.match(/crea_guia\\('WHR\\d+','(\\d+)'\\)/);\n  const casilleroId = creaM ? creaM[1] : '';\n\n  // Solo procesar los casilleros seleccionados\n  if (!casilleroIds.includes(casilleroId)) continue;\n\n  const tdMatches = [...block.matchAll(/<td class=\"reciboSMALLCAP\">\\s*([\\s\\S]*?)\\s*<\\/[Tt][Dd]>/g)];\n  const agencia = tdMatches[0] ? tdMatches[0][1].trim().replace(/<[^>]+>/g,'').replace(/\\s+/g,' ') : '';\n  const destinatario = tdMatches[2] ? tdMatches[2][1].replace(/<br>/gi,'|').replace(/<[^>]+>/g,'').trim() : '';\n  const valorDecReal = tdMatches[8] ? tdMatches[8][1].trim().replace(/<[^>]+>/g,'').trim() : '0';\n\n  const posM = block.match(/(Z[27]-[\\w-]+)/);\n  const posicion = posM ? posM[1] : '';\n\n  const pesoM = block.match(/name=\"pes_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const peso = pesoM ? pesoM[1].trim() : '';\n\n  const desM = block.match(/name=\"des_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const contenido = desM ? desM[1].trim() : '';\n\n  const decM = block.match(/name=\"dec_\\d+\" type=\"text\"[^>]*value=\"([^\"]*)\"/);\n  const valorDec = decM ? decM[1].trim() : '0';\n\n  const contenidoLower = contenido.toLowerCase();\n  const destLower = destinatario.toLowerCase();\n  const agenciaLower = agencia.toLowerCase();\n\n  const posValida          = REGLAS.posiciones_validas.some(p => posicion.startsWith(p));\n  const pesoNum            = parseFloat(peso) || 0;\n  const pesoValido         = pesoNum >= REGLAS.peso_minimo;\n  const bloqueado          = REGLAS.contenido_bloqueado.some(p => contenidoLower.includes(p));\n  const esDG               = REGLAS.contenido_dg.some(p => contenidoLower.includes(p));\n  const esCR               = REGLAS.contenido_cr.some(p => destLower.includes(p)) ||\n                             REGLAS.agencia_cr.some(p => agenciaLower.includes(p));\n  const valorDecNum        = parseFloat(valorDecReal) || 0;\n  const valorAlto          = valorDecNum > REGLAS.valor_declarado_max;\n  const casilleroBloqueado = REGLAS.casilleros_bloqueados_id.includes(casilleroId);\n\n  let skip = false;\n  let skipRazon = '';\n\n  if (casilleroBloqueado) { skip = true; skipRazon = 'CASILLERO_BLOQUEADO'; }\n  else if (!posValida)    { skip = true; skipRazon = 'SIN_POSICION'; }\n  else if (!pesoValido)   { skip = true; skipRazon = 'PESO_CERO'; }\n  else if (bloqueado)     { skip = true; skipRazon = 'CONTENIDO_BLOQUEADO'; }\n  else if (esCR)          { skip = true; skipRazon = 'COSTA_RICA'; }\n  else if (valorAlto)     { skip = true; skipRazon = `VALOR_ALTO_${valorDecNum}`; }\n\n  rows.push({ whr, manifestoId, casilleroId, agencia, destinatario, posicion,\n    peso: pesoNum, contenido, valorDec, valorDecReal, esDG, skip, skipRazon });\n}\n\nconst grupos = {};\nfor (const r of rows) {\n  const key = r.casilleroId || '__sin_casillero';\n  if (!grupos[key]) grupos[key] = [];\n  grupos[key].push(r);\n}\n\nconst resultados = [];\n\nfor (const [casId, guias] of Object.entries(grupos)) {\n  const validas  = guias.filter(g => !g.skip);\n  const omitidas = guias.filter(g => g.skip);\n  const tieneDG  = validas.some(g => g.esDG);\n\n  if (validas.length === 0 || omitidas.length > 0) continue;\n\n  const paItems = validas.map(g => `${g.peso}x0x0x0x${g.manifestoId}`);\n  resultados.push({\n    casilleroId:  casId,\n    agencia:      guias[0].agencia,\n    tipo:         tieneDG ? 'DG' : 'NORMAL',\n    whrsValidos:  validas.map(g => g.whr),\n    whrsStr:      validas.map(g => `'${g.whr}'`).join(','),\n    whrsBuscar:   validas.map(g => g.whr).join('%7C'),\n    pa:           paItems.join('|'),\n    piezas:       validas.length,\n    pesoTotal:    validas.reduce((s, g) => s + g.peso, 0).toFixed(2),\n    descripcion:  validas.map(g => g.contenido).join('\\n'),\n    valdec:       validas.reduce((s, g) => s + (parseFloat(g.valorDec) || 0), 0),\n    primerWhr:    validas[0].whr,\n    cookieNormal,\n    nomr: 'por confirmar', dirr: '8524 NW 61 ST', ciur: 'Miami',\n    estr: 'Florida', zipr: '33166', pair: 'USA', telr: '305-594-1100',\n    nAgencia: '00001', nprod: 'experto.col', producto: '16',\n  });\n}\n\nif (resultados.length === 0) {\n  return [{ json: { __sinGrupos: true, mensaje: 'Ningún grupo válido para despachar', cookieNormal }}];\n}\n\nreturn resultados.map(r => ({ json: r }));\n"
      }
    },
