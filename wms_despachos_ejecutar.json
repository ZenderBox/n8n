    {
      "id": "f4e3b9f4-72a2-4593-b110-4a5bef9b93a1",
      "name": "Parsear guias.asp",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2420,
        300
      ],
      "parameters": {
        "jsCode": "const html = $input.item.json.data || '';\nconst grupo = $('Split Grupos').item.json;\n\nif (html.length < 500) {\n  return [{ json: { ...grupo, _parseOk: false, _error: 'guias.asp respuesta vacía' }}];\n}\n\nfunction extractField(name) {\n  const m = html.match(new RegExp('name=\"' + name + '\"[^>]*value=\"([^\"]*)\"', 'i'));\n  return m ? m[1] : '';\n}\n\nconst casillero       = extractField('casillero');\nconst casillero_id    = extractField('casillero_id');\nconst CASILLEROS_BLOQUEADOS = ['ZB-114665'];\nif (CASILLEROS_BLOQUEADOS.includes(casillero)) {\n  return [{ json: { ...grupo, _parseOk: false, _error: `CASILLERO_BLOQUEADO - ${casillero}`, casillero }}];\n}\n\nconst guiaingreso     = extractField('guiaingreso');\nconst fletes          = extractField('fletes') || '0';\nconst Total           = extractField('Total') || '0';\nconst adicionales     = extractField('adicionales') || '0';\nconst h_adic_auto     = extractField('h_adicionales_auto') || '';\nconst Val_Dif_Vol     = extractField('Val_Dif_Vol') || '0';\nconst impuestotxt     = extractField('impuestotxt') || '0.00';\nconst seguro          = extractField('seguro') || '5.00';\nconst totalseguro     = extractField('totalseguro') || '0.00';\nconst pesovolumetrico = extractField('pesovolumetrico') || '0';\nconst paquetesadjuntos = extractField('paquetesadjuntos') || '';\nconst formaPago       = extractField('formaPago') || 'NP';\nconst nomd            = extractField('nomd');\nconst dird            = extractField('dird');\nconst des_nit         = extractField('des_nit');\nconst ciudades        = extractField('ciudades');\nconst ciudadesn       = extractField('ciudadesn');\nconst paises          = extractField('paises') || '1';\nconst paisesn         = extractField('paisesn');\nconst zipd            = extractField('zipd');\nconst teld            = extractField('teld');\nconst emaild          = extractField('emaild');\nconst celular_des     = extractField('celular_des');\nconst rem_id          = extractField('rem_id') || '';\nconst valdec          = extractField('valdec') || grupo.valdec || '0';\nconst diferenciaPeso  = extractField('diferenciaPeso') || '0';\nconst pesol2          = extractField('pesol2') || grupo.pesoTotal;\nconst pesovol         = extractField('pesovol') || '0.00';\n\nif (!Total || Total === '0') {\n  return [{ json: { ...grupo, _parseOk: false, _error: 'SIN_TARIFA - guía ya despachada o sin tarifa', casillero, guiaingreso }}];\n}\n\nreturn [{ json: {\n  ...grupo, _parseOk: true,\n  guiaingreso, fletes, Total, adicionales, h_adic_auto,\n  Val_Dif_Vol, impuestotxt, seguro, totalseguro,\n  pesovolumetrico, paquetesadjuntos, formaPago,\n  diferenciaPeso, pesol2, pesovol, valdec,\n  casillero, casillero_id_real: casillero_id,\n  nomd, dird, des_nit, ciudades, ciudadesn,\n  paises, paisesn, zipd, teld, emaild, celular_des, rem_id,\n}}];"
      }
    },
